# ============================================================
# 1) 轨迹几何工具：heading/横向偏移/简单指标
# ============================================================
def unwrap_angle(theta_1d: np.ndarray) -> np.ndarray:
    return np.unwrap(theta_1d)

def compute_heading(traj_xy: np.ndarray) -> np.ndarray:
    """
    traj_xy: [T,2] (单位：米)
    return yaw: [T] 由轨迹切向估计的航向（用于可视化指标）
    """
    d = np.diff(traj_xy, axis=0, prepend=traj_xy[:1])
    yaw = np.arctan2(d[:, 1], d[:, 0] + 1e-12)
    return unwrap_angle(yaw)

def frenet_lat_offset(traj_xy: np.ndarray) -> np.ndarray:
    """
    用初始航向定义横向轴，返回每个点的横向位移 lat: [T]
    """
    p0 = traj_xy[0]
    yaw0 = compute_heading(traj_xy)[0]
    e_lat = np.array([-np.sin(yaw0), np.cos(yaw0)], dtype=np.float64)
    dp = traj_xy - p0
    lat = dp @ e_lat
    return lat

def simple_metrics(traj_xy: np.ndarray) -> dict:
    """
    给一个中心轨迹 [T,2]，输出一些直观指标（用于图例/CSV）
    注意：delta_yaw 用轨迹切向估计，可能受 unwrap 影响；严格转角建议用动作 dyaw 累加。
    """
    yaw = compute_heading(traj_xy)
    lat = frenet_lat_offset(traj_xy)
    return {
        "end_x": float(traj_xy[-1, 0]),
        "end_y": float(traj_xy[-1, 1]),
        "delta_yaw": float(yaw[-1] - yaw[0]),
        "lat_abs_max": float(np.max(np.abs(lat))),
    }


# ============================================================
# 2) token -> 轨迹（中心点）解码：与你原版一致
# ============================================================
@torch.no_grad()
def decode_tokens_to_center_traj(
    tokenizer,
    token_batch: np.ndarray,          # [B,K] int
    init_polygons: torch.Tensor,      # [1,4,2] normalized
    state_range: float,
    num_components: int,
    device: str = "cuda:0",
) -> np.ndarray:
    """
    返回 center trajectories: [B,T,2] in meters
    """
    actions_np = tokenizer.decode(token_batch, num_components=num_components).astype(np.float32)  # [B,T,3]
    actions = torch.from_numpy(actions_np).to(device)
    # import pdb; pdb.set_trace()
    vx_act = actions[..., 0]
    vy_act = actions[..., 1]
    # 带符号v（没乘5，单位不是m/s）
    v = torch.sqrt(vx_act**2 + vy_act**2) * torch.sign(vx_act)

    B = actions.shape[0]
    init_poly_batch = init_polygons.to(device).repeat(B, 1, 1)

    polys = transform_polygon_torch_5s(init_poly_batch, actions, state_range=state_range) * state_range
    B, T, _, _ = polys.shape
    xyyaw =  get_xyyaw_from_polygon_torch(polys.reshape(B*T, 4, 2)).reshape(B, T, 3)

    return xyyaw.detach().cpu().numpy()


# ============================================================
# 3) sweep bins：按有效范围生成 + 强制包含 base_bin
# ============================================================
def choose_sweep_bins_in_valid_range(
    base_bin: int,
    k: int,
    n_points: int = 8,
) -> list:
    """
    使用你提供的 TOKEN_MIN/MAX 作为有效范围，均匀取 n_points 个点，
    并确保 base_bin 在 bins 里。
    """
    lo = int(TOKEN_MIN[k])
    hi = int(TOKEN_MAX[k])
    lo2 = 0
    hi2 = 1023

    cand = np.linspace(lo2, hi2, n_points).round().astype(int).tolist()
    cand.append(int(base_bin))
    cand = sorted(set([int(np.clip(x, lo2, hi2)) for x in cand]))
    return cand


# ============================================================
# 4) 绘图：在原 interventional_sweep_one_dim 上“最小改动”
#    - 增加 axis_limits 参数，保证所有图 xy 尺度一致
# ============================================================
def interventional_sweep_one_dim(
    tokenizer,
    base_tokens: np.ndarray,          # [K]
    sweep_dim: int,
    sweep_bins: list,
    init_polygons: torch.Tensor,
    state_range: float,
    num_components: int,
    out_dir: str,
    device: str = "cuda:0",
    title_prefix: str = "",
    axis_limits=None,                 # (xmin, xmax, ymin, ymax)
    tiers=None,
    fps: float = 5.0                  # <--- [新增参数] 默认为 5.0
):
    os.makedirs(out_dir, exist_ok=True)

    # 1) 组 batch：只改 sweep_dim
    token_batch = []
    for b in sweep_bins:
        t = base_tokens.copy()
        t[sweep_dim] = int(b)
        token_batch.append(t)
    token_batch = np.stack(token_batch, axis=0).astype(np.int32)  # [B,K]

    # 2) 解码得到中心轨迹
    xyyaw = decode_tokens_to_center_traj(
        tokenizer, token_batch, init_polygons, state_range, num_components, device=device
    )  # [B,T,2]

    vel, acc, jeck, kappa = get_vel_acc_kappa(xyyaw, dt=1/fps)

    kappa = np.clip(kappa, -10.0, 10.0)  # 限制曲率范围

    time_axis = np.arange(xyyaw.shape[1]) /fps  # [T] 时间轴

    # ==========================================================
    # [修改]：改为 2行3列 画板
    # ==========================================================
    # figsize 调大以容纳6张图
    fig, axes = plt.subplots(2, 3, figsize=(12, 8))

    # 分配子图对象
    ax_traj = axes[0, 0] # 轨迹 (原图)
    ax_yaw   = axes[0, 1]
    ax_kappa   = axes[0, 2]
    ax_vel   = axes[1, 0]
    ax_acc   = axes[1, 1]
    ax_jerk   = axes[1, 2]

    base_bin = int(base_tokens[sweep_dim])
    base_idx = sweep_bins.index(base_bin) if base_bin in sweep_bins else None

    # 用于统计当前这一组 sweep 的实际最大范围 (供你的逻辑使用)
    cur_xmin, cur_xmax = 1e9, -1e9
    cur_ymin, cur_ymax = 1e9, -1e9

    for i, b in enumerate(sweep_bins):
        x = xyyaw[i, :, 0]
        y = xyyaw[i, :, 1]

        # --- 收集当前数据的范围 ---
        cur_xmin = min(cur_xmin, np.min(x)); cur_xmax = max(cur_xmax, np.max(x))
        cur_ymin = min(cur_ymin, np.min(y)); cur_ymax = max(cur_ymax, np.max(y))

        lo = TOKEN_MIN[sweep_dim]
        hi = TOKEN_MAX[sweep_dim]
        is_oob = (b < lo) or (b > hi)

        label = f"bin={b}" # 简化一下label，不然6个图图例太挤

        # --- 统一样式 ---
        if is_oob:
            kwargs = dict(linestyle="--", linewidth=1.5, color="gray", alpha=0.9, marker='.', markersize=4)
            zorder = 1
        else:
            if base_idx is not None and i == base_idx:
                kwargs = dict(linewidth=3, marker='o', markersize=5)
                zorder = 3
            else:
                kwargs = dict(linewidth=1, alpha=0.9, marker='.', markersize=4)
                zorder = 2

        kwargs['label'] = label
        kwargs['zorder'] = zorder

        # 1. 画轨迹 (ax_traj)
        line, = ax_traj.plot(x, y, **kwargs)

        # 获取刚才自动分配的颜色 (如果是gray就gray，如果是自动色就取自动色)
        # 这样后面5个图的颜色能和轨迹对应上
        if 'color' not in kwargs:
            c = line.get_color()
            kwargs['color'] = c

        # 2. 画其他图 (X轴为时间)
        ax_vel.plot(time_axis, vel[i], **kwargs)
        ax_acc.plot(time_axis, acc[i], **kwargs)
        ax_yaw.plot(time_axis, xyyaw[i, :, 2], **kwargs)

        ax_kappa.plot(time_axis, kappa[i], **kwargs)
        ax_jerk.plot(time_axis, jeck[i], **kwargs)


    # ==========================================================
    # [关键]：恢复你原有的坐标轴逻辑，应用到 ax_traj
    # ==========================================================
    ax_traj.set_title(f"{title_prefix}Token {sweep_dim} sweep (base bin={base_bin})")
    ax_traj.set_xlabel("X")
    ax_traj.set_ylabel("Y")
    ax_traj.grid(True)

    # --- 其他子图的简单修饰 ---
    ax_vel.set_title("vel"); ax_vel.grid(True)
    ax_acc.set_title("acc"); ax_acc.grid(True)
    ax_yaw.set_title("yaw"); ax_yaw.grid(True)
    ax_kappa.set_title("kappa"); ax_kappa.grid(True); # ax_kappa.set_ylim(-1.1, 1.1) # 限制一下曲率范围防止飞出
    ax_jerk.set_title("jerk"); ax_jerk.grid(True)

    ax_vel.set_xlabel("time/s")
    ax_acc.set_xlabel("time/s")
    ax_yaw.set_xlabel("time/s")
    ax_kappa.set_xlabel("time/s")
    ax_jerk.set_xlabel("time/s")

    # 只需要在第一个图显示图例，避免拥挤
    ax_traj.legend(fontsize=6, loc="best")

    plt.tight_layout() # 自动调整间距
    xy_path = os.path.join(out_dir, f"token_{sweep_dim:02d}_sweep_combined.jpg")
    plt.savefig(xy_path, dpi=500)
    plt.close(fig)

    # 5) 保存指标 CSV
    csv_path = os.path.join(out_dir, f"token_{sweep_dim:02d}_sweep_metrics.csv")
    # df.to_csv(csv_path, index=False)

    return {"xy_path": xy_path, "csv_path": csv_path, "df": 0}

# ============================================================
def compute_scene_axis_pool(
    tokenizer,
    base_tokens: np.ndarray,          # [K]
    init_polygons: torch.Tensor,
    state_range: float,
    num_components: int,
    device: str,
    n_points_bins: int = 20,
    margin: float = 2.0,
    quantiles=(0.0, 0.6, 0.85, 0.95, 1.0),  # 自适应生成“几种档位”
    round_to: float = 1.0,            # 把 span 向上取整到多少米（保证“确定”）
):
    """
    返回：
      axis_limits_base: 最小档位对应的 (xmin,xmax,ymin,ymax) —— 作为 std box
      tiers: 该场景离散倍率列表（用于替换 TIERS），保证所有 token 都只能落在这些倍率里
      spans: 具体的 span 列表（米）
      scene_center: (cx, cy)
    """
    base_tokens = np.asarray(base_tokens).astype(np.int32)
    K = len(base_tokens)

    # 1) 先对每个 token 跑一遍 sweep（不画图，只统计 bbox）
    token_bboxes = []
    token_centers = []

    for k in range(K):
        sweep_bins = choose_sweep_bins_in_valid_range(int(base_tokens[k]), k, n_points=n_points_bins)

        token_batch = []
        for b in sweep_bins:
            t = base_tokens.copy()
            t[k] = int(b)
            token_batch.append(t)
        token_batch = np.stack(token_batch, axis=0).astype(np.int32)  # [B,K]

        centers = decode_tokens_to_center_traj(
            tokenizer, token_batch, init_polygons, state_range, num_components, device=device
        )  # [B,T,2]

        xmin = float(np.min(centers[..., 0]))
        xmax = float(np.max(centers[..., 0]))
        ymin = float(np.min(centers[..., 1]))
        ymax = float(np.max(centers[..., 1]))

        token_bboxes.append((xmin, xmax, ymin, ymax))
        token_centers.append(((xmin + xmax) / 2.0, (ymin + ymax) / 2.0))

    # 2) 用“中位数中心”做 scene center（抗 outlier，避免一个 token 把中心拉歪）
    cx = float(np.median([c[0] for c in token_centers]))
    cy = float(np.median([c[1] for c in token_centers]))

    # 3) 每个 token 相对 scene center 需要多大 span 才能包住
    needed_spans = []
    for (xmin, xmax, ymin, ymax) in token_bboxes:
        max_dist_x = max(abs(xmin - cx), abs(xmax - cx))
        max_dist_y = max(abs(ymin - cy), abs(ymax - cy))
        span = max(max_dist_x, max_dist_y) * 2.0 + margin * 2.0
        needed_spans.append(span)

    needed_spans = np.asarray(needed_spans, dtype=np.float64)

    # 4) 用分位数生成少量“固定 span 档位”
    spans = np.quantile(needed_spans, quantiles).astype(np.float64)

    # 向上取整到 round_to（让档位更“确定”、更规整）
    spans = np.ceil(spans / round_to) * round_to

    # 去重 + 排序 + 保证最后一个能 cover max
    spans = sorted(set([float(s) for s in spans]))
    spans[-1] = float(np.ceil(np.max(needed_spans) / round_to) * round_to)

    base_span = spans[0]
    half = base_span / 2.0
    axis_limits_base = (cx - half, cx + half, cy - half, cy + half)

    # 离散倍率（用于替换 TIERS）
    tiers = [s / base_span for s in spans]
    tiers[0] = 1.0  # 保底

    return axis_limits_base, tiers, spans, (cx, cy)
