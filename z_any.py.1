# ============================================================
# 5) 从 all_datas.npy 的 dxdydyaw 做类别筛选（复用你上一段采样逻辑的“特征定义”）
#    输出：features + 各类别 mask + 为每类选一个代表性 index
# ============================================================
def compute_motion_features(all_dxdydyaw_clips: np.ndarray, fps: float = 5.0, time_duration=None):
    """
    计算：net_yaw, gross_yaw, total_dist, avg_speed, sign_changes
    这里的 total_dist / avg_speed 使用“把局部 dx,dy 转到全局”来算（与之前采样函数一致口径）
    """
    clips = np.asarray(all_dxdydyaw_clips)
    N, T, _ = clips.shape
    dxs = clips[:, :, 0]
    dys = clips[:, :, 1]
    dyaws = clips[:, :, 2]

    cumulative_yaws = np.cumsum(dyaws, axis=1)  # [N,T]
    prev_yaws = np.zeros((N, T), dtype=dxs.dtype)
    prev_yaws[:, 1:] = cumulative_yaws[:, :-1]

    net_yaw = cumulative_yaws[:, -1] if T > 0 else np.zeros(N, dtype=np.float32)
    gross_yaw = np.sum(np.abs(dyaws), axis=1)

    cos_y = np.cos(prev_yaws)
    sin_y = np.sin(prev_yaws)
    dx_g = cos_y * dxs - sin_y * dys
    dy_g = sin_y * dxs + cos_y * dys

    step_d = np.sqrt(dx_g**2 + dy_g**2)
    total_dist = np.sum(step_d, axis=1)

    duration = time_duration if time_duration is not None else (T / fps)
    duration = max(float(duration), 1e-6)
    avg_speed = total_dist / duration  # m/s

    # dyaw 符号变化次数（粗略用于“绕行/S形”）
    s = np.sign(dyaws)
    s[s == 0] = 1
    sign_changes = np.sum(s[:, 1:] != s[:, :-1], axis=1)

    return {
        "net_yaw": net_yaw,
        "gross_yaw": gross_yaw,
        "total_dist": total_dist,
        "avg_speed": avg_speed,
        "sign_changes": sign_changes,
    }

def select_multi_type_bases_from_all_datas(all_trajs: np.ndarray, fps: float = 5.0):
    """
    从 all_trajs=[N,25,3] 中筛选你要的 7 类，并为每类选一个代表样本 index。
    返回 dict: name -> {"idx": int, "info": dict}
    """
    feat = compute_motion_features(all_trajs, fps=fps)

    net_yaw = feat["net_yaw"]
    gross_yaw = feat["gross_yaw"]
    total_dist = feat["total_dist"]
    avg_speed = feat["avg_speed"]
    sign_changes = feat["sign_changes"]

    # ---- 阈值（可按你数据分布微调）----
    TH_DIST_STATIC = 1.0

    TH_STRAIGHT_NET = 0.10
    TH_STRAIGHT_GROSS = 0.20

    # 速度阈值（m/s）
    V_10 = 10.0 / 3.6
    V_80 = 80.0 / 3.6
    V_120 = 120.0 / 3.6

    # 左/右转阈值
    TH_TURN = 0.35            # >20度开始认为“转弯”
    TH_UTURN = 2.35           # ~135度以上当“掉头/大回转”（你也可改成 3.0 更像180度）

    # ---- 类别 mask ----
    mask_static = (total_dist < TH_DIST_STATIC)

    mask_straight = (np.abs(net_yaw) < TH_STRAIGHT_NET) & (gross_yaw < TH_STRAIGHT_GROSS) & (~mask_static)

    mask_low_straight = mask_straight & (avg_speed >= (V_10 - 2/3.6)) & (avg_speed <= (V_10 + 2/3.6))
    mask_high_straight = mask_straight & (avg_speed >= (V_80 - 10/3.6)) & (avg_speed <= (V_80 + 10/3.6))
    mask_high_straight_120 = mask_straight & (avg_speed >= (V_120 - 15/3.6)) & (avg_speed <= (V_120 + 15/3.6))

    mask_left = (net_yaw >= TH_TURN) & (np.abs(net_yaw) < TH_UTURN) & (~mask_static)
    mask_right = (net_yaw <= -TH_TURN) & (np.abs(net_yaw) < TH_UTURN) & (~mask_static)

    # 绕行：最终回正（net 小），但过程转向大（gross 大），且 dyaw 符号变化次数较多
    mask_detour = (np.abs(net_yaw) < 0.20) & (gross_yaw >= 0.80) & (sign_changes >= 2) & (~mask_static)

    # 掉头：净转角特别大
    mask_uturn = (np.abs(net_yaw) >= TH_UTURN) & (~mask_static)

    categories = {
        "Stationary": mask_static,
        "LowSpeedStraight_10kmh": mask_low_straight,
        "HighSpeedStraight_80kmh": mask_high_straight,
        "HighSpeedStraight_120kmh": mask_high_straight_120,
        "LeftTurn": mask_left,
        "RightTurn": mask_right,
        "Detour": mask_detour,
        "UTurn": mask_uturn,
    }

    # ---- 为每类选一个“代表性” index：用一个简单 score ----
    out = {}
    for name, m in categories.items():
        idxs = np.where(m)[0]
        if len(idxs) == 0:
            out[name] = {"idx": None, "info": {"count": 0}}
            continue

        if name == "Stationary":
            score = total_dist[idxs]  # 越小越静止
        elif name == "LowSpeedStraight_10kmh":
            score = np.abs(avg_speed[idxs] - V_10) + 0.5*np.abs(net_yaw[idxs]) + 0.2*gross_yaw[idxs]
        elif name == "HighSpeedStraight_80kmh":
            score = np.abs(avg_speed[idxs] - V_80) + 0.5*np.abs(net_yaw[idxs]) + 0.2*gross_yaw[idxs]
        elif name == "HighSpeedStraight_120kmh":
            score = np.abs(avg_speed[idxs] - V_120) + 0.5*np.abs(net_yaw[idxs]) + 0.2*gross_yaw[idxs]
        elif name == "LeftTurn":
            # 选一个“中等”左转：更稳（避免太极端）
            score = np.abs(net_yaw[idxs] - 1.0) + 0.05*np.abs(avg_speed[idxs] - V_10)
        elif name == "RightTurn":
            score = np.abs(net_yaw[idxs] + 1.0) + 0.05*np.abs(avg_speed[idxs] - V_10)
        elif name == "Detour":
            # 绕行：更偏向 gross 大、sign_changes 多、net 小
            score = (np.abs(net_yaw[idxs]) * 1.0) + (1.0 / (gross_yaw[idxs] + 1e-6)) + (1.0 / (sign_changes[idxs] + 1e-6))
        elif name == "UTurn":
            # 掉头：选 net_yaw 绝对值更接近 pi 的（更像180度）
            score = np.abs(np.abs(net_yaw[idxs]) - np.pi)

        best_local = int(idxs[np.argmin(score)])
        out[name] = {
            "idx": best_local,
            "info": {
                "count": int(len(idxs)),
                "net_yaw": float(net_yaw[best_local]),
                "gross_yaw": float(gross_yaw[best_local]),
                "total_dist": float(total_dist[best_local]),
                "avg_speed_mps": float(avg_speed[best_local]),
                "avg_speed_kmh": float(avg_speed[best_local] * 3.6),
                "sign_changes": int(sign_changes[best_local]),
            }
        }

    return out


# ============================================================
# 6) 对每个类别：用其 base trajectory -> encode 得到 base_tokens，然后跑 sweep
#    同时：先计算“全局 axis_limits”，保证所有图尺度一致
# ============================================================
def encode_base_tokens_from_traj(tokenizer, traj_25x3: np.ndarray, num_components: int):
    """
    traj_25x3: [25,3] -> base_tokens: [K]
    """
    toks = tokenizer(traj_25x3[None, ...], num_components=num_components)  # [1,K]
    base_tokens = toks[0].astype(np.int32)

    # 安全：clip 到你给的有效范围
    for k in range(len(base_tokens)):
        # base_tokens[k] = int(np.clip(base_tokens[k], TOKEN_MIN[k], TOKEN_MAX[k]))
        base_tokens[k] = int(np.clip(base_tokens[k], 0, 1023))
    return base_tokens

def compute_global_axis_limits(
    tokenizer,
    base_tokens_dict: dict,   # name -> base_tokens
    init_polygons: torch.Tensor,
    state_range: float,
    num_components: int,
    device: str,
    n_points: int = 8,
    margin: float = 20.0,     # 保持 20.0 或 30.0，作为“标准视野”
):
    """
    只计算 Base Trajectory 的范围作为“标准画框”。
    """
    xmin, xmax = 1e9, -1e9
    ymin, ymax = 1e9, -1e9

    for name, base_tokens in base_tokens_dict.items():
        # 只解码 Base Token
        token_batch = np.array([base_tokens], dtype=np.int32)

        centers = decode_tokens_to_center_traj(
            tokenizer, token_batch, init_polygons, state_range, num_components, device=device
        )  # [1,T,2]

        # 更新范围
        xmin = min(xmin, float(np.min(centers[..., 0])))
        xmax = max(xmax, float(np.max(centers[..., 0])))
        ymin = min(ymin, float(np.min(centers[..., 1])))
        ymax = max(ymax, float(np.max(centers[..., 1])))

    # --- 强制正方形视野 ---
    cx = (xmin + xmax) / 2.0
    cy = (ymin + ymax) / 2.0

    span_x = xmax - xmin
    span_y = ymax - ymin

    # 取长宽中较大者，并加上 margin
    max_span = max(span_x, span_y) + margin * 2
    half_span = max_span / 2.0

    # 返回标准框 (Standard Box)
    return (cx - half_span, cx + half_span, cy - half_span, cy + half_span)

def run_scan_for_all_bases(
    tokenizer,
    all_trajs: np.ndarray,
    init_polygons: torch.Tensor,
    state_range: float,
    num_components: int,
    out_root: str,
    device: str,
    fps: float = 5.0,
    n_points_bins: int = 8,
):
    os.makedirs(out_root, exist_ok=True)

    # 1) 选每类 base trajectory index
    base_sel = select_multi_type_bases_from_all_datas(all_trajs, fps=fps)

    # 2) 为每类生成 base_tokens（由真实轨迹 encode 得到）
    base_tokens_dict = {}
    base_info_rows = []
    for name, pack in base_sel.items():
        idx = pack["idx"]
        if idx is None:
            print(f"[WARN] category={name} has 0 samples. skip.")
            continue
        base_traj = all_trajs[idx]  # [25,3]
        base_tokens = encode_base_tokens_from_traj(tokenizer, base_traj, num_components=num_components)
        base_tokens_dict[name] = base_tokens

        row = {"category": name, "base_idx": int(idx), **pack["info"]}
        base_info_rows.append(row)

    # pd.DataFrame(base_info_rows).to_csv(os.path.join(out_root, "base_selection_summary.csv"), index=False)
    print(f"[OK] Base selection summary saved: {os.path.join(out_root, 'base_selection_summary.csv')}")

    if len(base_tokens_dict) == 0:
        print("[ERROR] No valid base categories found. Nothing to run.")
        return

    # 3) 对每个类别跑 sweep
    K = len(TOKEN_MIN)
    for name, base_tokens in base_tokens_dict.items():
        out_dir = os.path.join(out_root, name)
        os.makedirs(out_dir, exist_ok=True)

        # 只在这里算一次（不要放进 for k 循环里）
        axis_limits_scene = compute_global_axis_limits(
            tokenizer=tokenizer,
            base_tokens_dict={name: base_tokens},   # 只用当前场景
            init_polygons=init_polygons,
            state_range=state_range,
            num_components=num_components,
            device=device,
            n_points=n_points_bins,
            margin=5.0,
        )
        print(f"[OK] {name} axis_limits_scene:", axis_limits_scene)

        print(f"\n===== Running category base: {name} =====")
        print("base_tokens:", base_tokens.tolist())

        # --- 新增：每个场景只算一次“固定档位坐标轴池” ---
        axis_limits_scene, tiers_scene, spans_scene, scene_center = compute_scene_axis_pool(
            tokenizer=tokenizer,
            base_tokens=base_tokens,
            init_polygons=init_polygons,
            state_range=state_range,
            num_components=num_components,
            device=device,
            n_points_bins=n_points_bins,
            margin=2.0,
            # quantiles=(0.0, 0.6, 0.85, 0.95, 1.0),  # 你可以改成 3~6 个分位点 = “几种范围”
            quantiles=(0.0, 0.5, 1.0),  # 你可以改成 3~6 个分位点 = “几种范围”
            round_to=1.0,
        )
        print(f"[OK] {name} scene_center={scene_center}, spans={spans_scene}, tiers={tiers_scene}")

        for k in range(K):
            sweep_bins = choose_sweep_bins_in_valid_range(int(base_tokens[k]), k, n_points=n_points_bins)

            interventional_sweep_one_dim(
                tokenizer=tokenizer,
                base_tokens=base_tokens,
                sweep_dim=k,
                sweep_bins=sweep_bins,
                init_polygons=init_polygons,
                state_range=state_range,
                num_components=num_components,
                out_dir=out_dir,
                device=device,
                title_prefix=f"[{name}] ",
                axis_limits=axis_limits_scene,   # 固定 std box（场景级中心+最小 span）
                tiers=tiers_scene,               # 固定离散档位（保证所有 token 只落在这几档）
                fps=fps,
            )


        print(f"[DONE] category={name} saved to: {out_dir}")



